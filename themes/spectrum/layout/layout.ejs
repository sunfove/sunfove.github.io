<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <%- partial('partials/head') %>
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">
  <canvas id="particleBg" aria-hidden="true"></canvas>
  <a class="skip-link" href="#main">跳到正文</a>
  <%- partial('partials/nav') %>
  <main id="main">
    <%- body %>
  </main>
  <%- partial('partials/footer') %>
  <script src="<%- url_for('/js/ripple.js') %>" defer></script>
  <script src="<%- url_for('/js/scenes.js') %>" defer></script>
  <script src="<%- url_for('/js/main.js') %>" defer></script>
  <script src="<%- url_for('/js/performance.js') %>" defer></script>
  <% if (page.__post) { %>
    <%- partial('partials/math') %>
  <% } %>
</body>
</html>
