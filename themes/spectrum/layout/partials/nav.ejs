<header class="site-nav" id="siteNav">
  <div class="nav-inner">
    <a class="brand" href="<%- url_for('/') %>">
      <span class="brand-spectrum" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span>
      <span class="brand-name"><%= config.title %></span>
    </a>
    <nav class="nav-links" id="navLinks" aria-label="主导航">
      <% (theme.nav || []).forEach(function (item) { %>
        <a href="<%- url_for(item.link) %>" class="nav-link<%= (item.link === '/' ? is_home() : (page.path || '').indexOf(item.link.replace(/^\//, '')) === 0) ? ' is-active' : '' %>"><%= item.name %></a>
      <% }) %>
    </nav>
    <div class="nav-actions">
      <a class="nav-icon-link" href="<%- url_for('/search/') %>" title="搜索" aria-label="搜索">
        <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </a>
      <button class="theme-toggle" id="themeToggle" type="button" title="切换明暗" aria-label="切换明暗主题">
        <svg class="icon-sun" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
      </button>
      <button class="nav-burger" id="navBurger" type="button" aria-label="展开菜单" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
