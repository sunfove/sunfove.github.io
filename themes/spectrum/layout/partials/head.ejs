<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<%
  var siteTitle = config.title;
  var pageTitle = page.title ? page.title + ' · ' + siteTitle : siteTitle + ' — ' + (config.subtitle || '');
  var desc = page.description || config.description || '';
%>
<title><%= pageTitle %></title>
<meta name="description" content="<%= String(desc).replace(/"/g, '&quot;') %>">
<meta name="author" content="<%= config.author %>">
<link rel="canonical" href="<%= full_url_for(page.path || '') %>">
<% if (page.__post) { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": <%- JSON.stringify(page.title || '') %>,
  "description": <%- JSON.stringify(String(page.description || '').substring(0, 200)) %>,
  "url": <%- JSON.stringify(full_url_for(page.path)) %>,
  "datePublished": <%- JSON.stringify(page.date ? page.date.toISOString() : '') %>,
  "dateModified": <%- JSON.stringify((page.updated || page.date) ? (page.updated || page.date).toISOString() : '') %>,
  "author": { "@type": "Person", "name": <%- JSON.stringify(config.author || '') %> },
  "publisher": { "@type": "Person", "name": <%- JSON.stringify(config.author || '') %> }
}
</script>
<% } %>
<!-- Resource hints: early DNS + connection for external origins -->
<link rel="dns-prefetch" href="//hm.baidu.com">
<link rel="preconnect" href="//hm.baidu.com" crossorigin>
<link rel="dns-prefetch" href="//suncos-01-1254144885.cos.ap-shanghai.myqcloud.com">
<link rel="preconnect" href="//suncos-01-1254144885.cos.ap-shanghai.myqcloud.com" crossorigin>
<link rel="dns-prefetch" href="//cdn.jsdelivr.net">
<link rel="dns-prefetch" href="//at.alicdn.com">
<link rel="preload" href="<%- url_for('/css/spectrum.css') %>" as="style">
<link rel="stylesheet" href="<%- url_for('/css/spectrum.css') %>">
<script>
/* 防闪烁：首绘前确定四时场景与明暗主题（与 js/scenes.js 逻辑一致） */
(function () {
  try {
    var h = new Date().getHours();
    var scene = (h >= 5 && h < 8) ? 'dawn' : (h >= 8 && h < 17) ? 'day' : (h >= 17 && h < 20) ? 'dusk' : 'midnight';
    var manual = false, saved = null;
    try {
      manual = sessionStorage.getItem('spectrum-manual') === '1';
      saved = localStorage.getItem('spectrum-theme');
    } catch (e2) {}
    var dark;
    if (manual && saved) dark = saved === 'dark';
    else if (scene === 'midnight') dark = true;
    else if (saved) dark = saved === 'dark';
    else dark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    var de = document.documentElement;
    de.setAttribute('data-theme', dark ? 'dark' : 'light');
    de.setAttribute('data-scene', scene);
  } catch (e) {
    document.documentElement.setAttribute('data-theme', 'light');
    document.documentElement.setAttribute('data-scene', 'day');
  }
})();
</script>
<noscript><style>.no-js-hide{display:none}</style></noscript>
