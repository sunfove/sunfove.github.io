<% if (page.prev || page.next) { %>
<nav class="pager" aria-label="分页导航">
  <% if (page.prev) { %>
    <a class="pager-link is-prev" href="<%- url_for(page.prev_link) %>" rel="prev">← 上一页</a>
  <% } else { %>
    <span class="pager-link is-disabled" aria-hidden="true">← 上一页</span>
  <% } %>

  <span class="pager-info">第 <%= page.current %> / <%= page.total %> 页</span>

  <% if (page.next) { %>
    <a class="pager-link is-next" href="<%- url_for(page.next_link) %>" rel="next">下一页 →</a>
  <% } else { %>
    <span class="pager-link is-disabled" aria-hidden="true">下一页 →</span>
  <% } %>
</nav>
<% } %>
